# ============================================================
#  OperWiki AI Platform — Environment Variables
#  Copy this file to .env.local and fill in your values
# ============================================================

# Azure OpenAI (required for AI features)
AZURE_OPENAI_ENDPOINT=https://operwiki-ai.openai.azure.com/
AZURE_OPENAI_KEY=2TNmwi0i9Z4NT3kD5fZrILOgLr43RGF2EWCpTKWeJEzwVZeZLcZYJQQJ99CCACYeBjFXJ3w3AAABACOGbsOj
AZURE_OPENAI_DEPLOYMENT=gpt-4o
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-ada-002

# Auth (dev: leave as-is | prod: set Azure AD values)
JWT_SECRET=change-this-to-a-long-random-string
AUTH_MODE=local

# Azure AD (prod only)
AZURE_AD_TENANT_ID=your-tenant-id
AZURE_AD_CLIENT_ID=your-client-id
AZURE_AD_CLIENT_SECRET=your-client-secret

# MS Forms webhook security (optional but recommended)
WEBHOOK_SECRET=choose-a-secret-string

# Frontend URL (used for CORS)
FRONTEND_URL=http://localhost:3000
